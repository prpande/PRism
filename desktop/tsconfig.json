{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    // moduleResolution "Node" (node10) is deprecated in TS 6 and removed in TS 7.
    // ignoreDeprecations keeps the TS 6 bump (#335) behavior-identical for now;
    // migrating to node16/nodenext changes import-resolution semantics and is
    // deferred to its own follow-up issue (tracked) before the TS 7 bump.
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": ["src/**/*.ts"]
}
