root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,csproj,sln,props,targets}]
indent_style = space
indent_size = 4

[*.{ts,tsx,js,jsx,json,jsonc,css,html,md,yml,yaml}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
